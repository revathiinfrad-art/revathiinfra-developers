rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getEmployee(uid) {
      return get(/databases/$(database)/documents/employees/$(uid)).data;
    }

    function isEmployee() {
      return isSignedIn() && exists(/databases/$(database)/documents/employees/$(request.auth.uid));
    }

    function isAdmin() {
      return isEmployee() && getEmployee(request.auth.uid).role == 'admin';
    }

    // --- Validation Helpers ---
    function isValidEmployee(data) {
      return data.keys().hasAll(['employeeId', 'username', 'role', 'email']) 
        && data.employeeId is string && data.employeeId.size() <= 20
        && data.username is string && data.username.size() <= 50
        && data.role in ['admin', 'staff']
        && data.email == request.auth.token.email;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'location', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() <= 100
        && data.location is string && data.location.size() <= 200
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidPlot(data) {
      return data.keys().hasAll(['projectId', 'plotNumber', 'status'])
        && data.projectId is string && data.projectId.size() <= 100
        && data.plotNumber is string && data.plotNumber.size() <= 20
        && data.status in ['Available', 'Sold', 'Reserved']
        && (data.status != 'Sold' || (data.keys().hasAll(['customerName', 'customerContact'])));
    }

    // --- Collections ---

    // Employees
    match /employees/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidEmployee(incoming());
      allow update: if isAdmin() && isValidEmployee(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'username', 'employeeId', 'name', 'photoUrl']);
      allow delete: if isAdmin();
    }

    // Projects
    match /projects/{projectId} {
      allow get, list: if isEmployee();
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isAdmin() && isValidProject(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();

      // Plots subcollection
      match /plots/{plotId} {
        allow get, list: if isEmployee();
        allow create: if isAdmin() && isValidId(plotId) && isValidPlot(incoming());
        allow update: if isEmployee() && isValidPlot(incoming()) && (
          // Admin can change everything
          isAdmin() || 
          // Staff can only change status and customer details
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'customerName', 'customerContact', 'updatedAt', 'updatedBy']))
        ) && incoming().projectId == existing().projectId;
        allow delete: if isAdmin();
      }
    }
  }
}
